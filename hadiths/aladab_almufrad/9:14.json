{"id":14,"idInBook":169,"chapterId":9,"bookId":15,"arabic":"حَدَّثَنَا حَجَّاجٌ، قَالَ‏:‏ حَدَّثَنَا شُعْبَةُ قَالَ‏:‏ أَنْبَأَنَا أَبُو إِسْحَاقَ قَالَ‏:‏ سَمِعْتُ حَارِثَةَ بْنَ مُضَرِّبٍ قَالَ‏:‏ سَمِعْتُ سَلْمَانَ‏:‏ إِنِّي لَأَعُدُّ الْعُرَاقَ خَشْيَةَ الظَّنِّ‏.‏","english":{"narrator":"","text":"same as 168."},"hadithNumber":169,"hadithId":14,"reference":"9:14","meta":{"id":"aladab_almufrad","length":1326,"totalChapters":57,"arabic":{"title":"الأدب المفرد","author":"الإمام محمد بن إسماعيل البخاري"},"english":{"title":"Al-Adab Al-Mufrad","author":"Imam Muhammad ibn Ismail al-Bukhari"}},"chapter":{"id":9,"bookId":15,"arabic":"كتاب الملكة","english":"Being a master","startHadith":156,"endHadith":211,"totalHadiths":56},"version":{"name":"aladab_almufrad","title":"Al-Adab Al-Mufrad","chapters":57}}