{"id":14,"idInBook":97,"chapterId":5,"bookId":15,"arabic":"وَعَنْ عَبْدَةَ، عَنِ ابْنِ أَبِي خَالِدٍ، عَنْ قَيْسٍ، عَنْ جَرِيرِ بْنِ عَبْدِ اللهِ قَالَ‏:‏ قَالَ رَسُولُ اللهِ صلى الله عليه وسلم‏:‏ مَنْ لاَ يَرْحَمُ النَّاسَ لا يَرْحَمُهُ اللَّهُ‏.‏","english":{"narrator":"","text":"Same as 97."},"hadithNumber":97,"hadithId":14,"reference":"5:14","meta":{"id":"aladab_almufrad","length":1326,"totalChapters":57,"arabic":{"title":"الأدب المفرد","author":"الإمام محمد بن إسماعيل البخاري"},"english":{"title":"Al-Adab Al-Mufrad","author":"Imam Muhammad ibn Ismail al-Bukhari"}},"chapter":{"id":5,"bookId":15,"arabic":"كتاب رعاية الأولاد","english":"Looking after children","startHadith":84,"endHadith":100,"totalHadiths":17},"version":{"name":"aladab_almufrad","title":"Al-Adab Al-Mufrad","chapters":57}}