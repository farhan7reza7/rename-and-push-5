{"id":107,"idInBook":286,"chapterId":2,"bookId":17,"arabic":"وَزَادَ أَحْمَدُ : \n\"وَاحِدَةً أَوْ دَعْ\"  1‏‏1 ‏- صحيح .‏ رواه أحمد (5/163)‏ وهو وإن كان في سنده ابن أبي ليلى وهو متكلم فيه من قبل حفظه إلا أنه حفظه ، ومما يدل على ذلك الحديث التالي .‏","english":{"narrator":"And Ahmad added to the above Hadith:","text":"\"(remove the pebbles) once or leave (them).\""},"hadithNumber":286,"hadithId":107,"reference":"2:107","meta":{"id":"bulugh_almaram","length":1767,"totalChapters":16,"arabic":{"title":"بلوغ المرام","author":"الإمام ابن حجر العسقلاني"},"english":{"title":"Bulugh Al Maram","author":"Ibn Hajar al-Asqalani"}},"chapter":{"id":2,"bookId":17,"arabic":"كتاب الصلاة","english":"The Book of Prayer","startHadith":180,"endHadith":640,"totalHadiths":461},"version":{"name":"bulugh_almaram","title":"Bulugh Al Maram","chapters":16}}