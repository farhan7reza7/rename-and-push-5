{"id":63,"idInBook":5619,"chapterId":77,"bookId":1,"arabic":"حَدَّثَنَا مُسَدَّدٌ، حَدَّثَنَا عَبْدُ الْوَارِثِ، عَنْ عَبْدِ الْعَزِيزِ، عَنْ أَنَسٍ، قَالَ نَهَى النَّبِيُّ صلى الله عليه وسلم أَنْ يَتَزَعْفَرَ الرَّجُلُ‏.‏","english":{"narrator":"Narrated Anas:","text":"The Prophet (ﷺ) forbade men to use saffron."},"hadithNumber":5619,"vol":7,"hadithId":63,"reference":"77:63","meta":{"id":"bukhari","length":7563,"totalChapters":97,"arabic":{"title":"صحيح البخاري","author":"الإمام محمد بن إسماعيل البخاري"},"english":{"title":"Sahih Al Bukhari","author":"Imam Muhammad ibn Ismail al-Bukhari"}},"chapter":{"id":77,"bookId":1,"arabic":"كتاب اللباس","english":"Dress","startHadith":5557,"endHadith":5741,"totalHadiths":185},"version":{"name":"bukhari","title":"Sahih Al Bukhari","chapters":97}}