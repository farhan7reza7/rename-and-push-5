{"id":47,"idInBook":1395,"chapterId":24,"bookId":1,"arabic":"وَقَالَ حَنْظَلَةُ عَنْ طَاوُسٍ، ‏\"‏ جُنَّتَانِ ‏\"‏‏.‏ وَقَالَ اللَّيْثُ حَدَّثَنِي جَعْفَرٌ، عَنِ ابْنِ هُرْمُزٍ، سَمِعْتُ أَبَا هُرَيْرَةَ ـ رضى الله عنه ـ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏\"‏ جُنَّتَانِ ‏\"‏‏.‏","english":{"narrator":"","text":"See previous hadith."},"hadithNumber":1395,"vol":2,"hadithId":47,"reference":"24:47","meta":{"id":"bukhari","length":7563,"totalChapters":97,"arabic":{"title":"صحيح البخاري","author":"الإمام محمد بن إسماعيل البخاري"},"english":{"title":"Sahih Al Bukhari","author":"Imam Muhammad ibn Ismail al-Bukhari"}},"chapter":{"id":24,"bookId":1,"arabic":"كتاب الزكاة","english":"Obligatory Charity Tax (Zakat)","startHadith":1349,"endHadith":1460,"totalHadiths":112},"version":{"name":"bukhari","title":"Sahih Al Bukhari","chapters":97}}