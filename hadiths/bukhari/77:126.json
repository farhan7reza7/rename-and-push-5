{"id":126,"idInBook":5682,"chapterId":77,"bookId":1,"arabic":"وَقَالَ هِشَامٌ عَنْ مَعْمَرٍ، عَنْ قَتَادَةَ، عَنْ أَنَسٍ، كَانَ النَّبِيُّ صلى الله عليه وسلم شَثْنَ الْقَدَمَيْنِ وَالْكَفَّيْنِ‏.‏","english":{"narrator":"Narrated Anas:","text":"The Prophet (ﷺ) had big feet and hands."},"hadithNumber":5682,"vol":7,"hadithId":126,"reference":"77:126","meta":{"id":"bukhari","length":7563,"totalChapters":97,"arabic":{"title":"صحيح البخاري","author":"الإمام محمد بن إسماعيل البخاري"},"english":{"title":"Sahih Al Bukhari","author":"Imam Muhammad ibn Ismail al-Bukhari"}},"chapter":{"id":77,"bookId":1,"arabic":"كتاب اللباس","english":"Dress","startHadith":5557,"endHadith":5741,"totalHadiths":185},"version":{"name":"bukhari","title":"Sahih Al Bukhari","chapters":97}}