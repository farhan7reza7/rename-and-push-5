{"id":7,"idInBook":5048,"chapterId":68,"bookId":1,"arabic":"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مُحَمَّدٍ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ أَبِي الْوَزِيرِ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ، عَنْ حَمْزَةَ، عَنْ أَبِيهِ، وَعَنْ عَبَّاسِ بْنِ سَهْلِ بْنِ سَعْدٍ، عَنْ أَبِيهِ، بِهَذَا‏.‏","english":{"narrator":"Narrated Sahl bin Sa`d:","text":"similarly as above (182)."},"hadithNumber":5048,"vol":6,"hadithId":7,"reference":"68:7","meta":{"id":"bukhari","length":7563,"totalChapters":97,"arabic":{"title":"صحيح البخاري","author":"الإمام محمد بن إسماعيل البخاري"},"english":{"title":"Sahih Al Bukhari","author":"Imam Muhammad ibn Ismail al-Bukhari"}},"chapter":{"id":68,"bookId":1,"arabic":"كتاب الطلاق","english":"Divorce","startHadith":5042,"endHadith":5136,"totalHadiths":95},"version":{"name":"bukhari","title":"Sahih Al Bukhari","chapters":97}}