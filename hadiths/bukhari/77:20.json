{"id":20,"idInBook":5576,"chapterId":77,"bookId":1,"arabic":"وَقَالَ لِي مُسَدَّدٌ حَدَّثَنَا مُعْتَمِرٌ، سَمِعْتُ أَبِي قَالَ، رَأَيْتُ عَلَى أَنَسٍ بُرْنُسًا أَصْفَرَ مِنْ خَزٍّ‏.‏","english":{"narrator":"Narrated Mu'tamir:","text":"I heard my father saying, \"I saw Anas wearing a yellow hooded cloak of Khazz.\""},"hadithNumber":5576,"vol":7,"hadithId":20,"reference":"77:20","meta":{"id":"bukhari","length":7563,"totalChapters":97,"arabic":{"title":"صحيح البخاري","author":"الإمام محمد بن إسماعيل البخاري"},"english":{"title":"Sahih Al Bukhari","author":"Imam Muhammad ibn Ismail al-Bukhari"}},"chapter":{"id":77,"bookId":1,"arabic":"كتاب اللباس","english":"Dress","startHadith":5557,"endHadith":5741,"totalHadiths":185},"version":{"name":"bukhari","title":"Sahih Al Bukhari","chapters":97}}